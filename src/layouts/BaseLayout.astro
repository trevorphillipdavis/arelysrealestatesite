---
interface Props {
  title?: string;
}

const { title = "Buy or Sell Your Next Home With Arelys Catena" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- FontAwesome for social media and icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans min-h-screen flex flex-col">
    
    <!-- HEADER -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-50 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-20">
          
          <!-- Left: Logo & Branding linked to main site -->
          <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
            <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-[#C59B27] shadow-sm flex-shrink-0">
              <img src="https://placehold.co/150x150/C59B27/white?text=AC" alt="Arelys Catena" class="w-full h-full object-cover" />
            </div>
            <div>
              <div class="flex items-center gap-1.5">
                <span class="bg-[#C59B27] text-white font-bold px-2 py-0.5 rounded text-xs">C21</span>
                <span class="font-bold text-gray-900 text-lg tracking-tight">Arelys Catena</span>
              </div>
              <p class="text-xs text-[#C59B27] font-medium">Real Estate</p>
            </div>
          </a>

          <!-- Middle / Right Nav & Contact Info -->
          <div class="flex items-center space-x-6 lg:space-x-8">
            
            <!-- Persistent Contact Info in Header -->
            <div class="hidden xl:flex items-center space-x-4 border-l border-gray-200 pl-6 text-xs text-gray-600">
              <div class="flex items-center gap-1.5">
                <i class="fa-solid fa-phone text-[#C59B27]"></i>
                <a href="tel:9542923366" class="hover:text-[#C59B27] font-semibold">(954) 292-3366</a>
              </div>
              <div class="flex items-center gap-1.5">
                <i class="fa-solid fa-envelope text-[#C59B27]"></i>
                <a href="mailto:arelyshomes@gmail.com" class="hover:text-[#C59B27] font-semibold">arelyshomes@gmail.com</a>
              </div>
            </div>

            <!-- Social Media Logos -->
            <div class="hidden md:flex items-center space-x-3 text-gray-600 border-l border-gray-200 pl-6">
              <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center hover:bg-[#C59B27] hover:text-white transition-colors">
                <i class="fa-brands fa-facebook-f text-sm"></i>
              </a>
              <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center hover:bg-[#C59B27] hover:text-white transition-colors">
                <i class="fa-brands fa-instagram text-sm"></i>
              </a>
              <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center hover:bg-[#C59B27] hover:text-white transition-colors">
                <i class="fa-brands fa-linkedin-in text-sm"></i>
              </a>
            </div>

            <!-- Navigation Links -->
            <nav class="hidden md:flex items-center space-x-6 text-sm font-medium">
              <a href="/" class="text-gray-700 hover:text-[#C59B27] transition-colors">Home</a>
              <a href="https://arelystheamazingrealtor.com/search" class="text-gray-700 hover:text-[#C59B27] transition-colors">Search Homes</a>
              <a href="/blog" class="text-gray-700 hover:text-[#C59B27] transition-colors">Local Market News</a>
              <a href="/reviews" class="text-gray-700 hover:text-[#C59B27] transition-colors">Customer Testimonials</a>
            </nav>

            <!-- MLS Search CTA Button -->
            <a href="https://arelystheamazingrealtor.com/search" class="bg-[#C59B27] hover:bg-[#b0881f] text-white px-4 py-2.5 rounded-lg font-semibold text-sm shadow-sm transition-colors hidden sm:inline-block">
              MLS Search
            </a>

          </div>
        </div>
      </div>
    </header>

    <!-- MAIN CONTENT SLOT -->
    <div class="flex-grow">
      <slot />
    </div>

    <!-- FOOTER -->
    <footer class="bg-gray-900 text-gray-300 py-12 mt-20 border-t border-gray-800">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-[#C59B27] text-white font-bold px-2 py-1 rounded text-sm">C21</span>
            <span class="text-white font-bold text-lg">Arelys Catena</span>
          </div>
          <p class="text-sm text-gray-400">Dedicated to providing expert local market knowledge, unmatched negotiation skills, and personal service across South Florida.</p>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/" class="hover:text-[#C59B27]">Home</a></li>
            <li><a href="https://arelystheamazingrealtor.com/search" class="hover:text-[#C59B27]">Search Homes</a></li>
            <li><a href="/blog" class="hover:text-[#C59B27]">Local Market News</a></li>
            <li><a href="/reviews" class="hover:text-[#C59B27]">Customer Testimonials</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact Arelys</h3>
          <p class="text-sm text-gray-400 mb-2"><i class="fa-solid fa-phone text-[#C59B27] mr-2"></i> (954) 292-3366</p>
          <p class="text-sm text-gray-400 mb-4"><i class="fa-solid fa-envelope text-[#C59B27] mr-2"></i> arelyshomes@gmail.com</p>
          <div class="flex space-x-3">
            <a href="https://facebook.com" target="_blank" class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center text-gray-300 hover:bg-[#C59B27] hover:text-white transition-colors">
              <i class="fa-brands fa-facebook-f text-sm"></i>
            </a>
            <a href="https://instagram.com" target="_blank" class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center text-gray-300 hover:bg-[#C59B27] hover:text-white transition-colors">
              <i class="fa-brands fa-instagram text-sm"></i>
            </a>
            <a href="https://linkedin.com" target="_blank" class="w-8 h-8 rounded-full bg-gray-800 flex items-center justify-center text-gray-300 hover:bg-[#C59B27] hover:text-white transition-colors">
              <i class="fa-brands fa-linkedin-in text-sm"></i>
            </a>
          </div>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-10 pt-6 border-t border-gray-800 text-xs text-gray-500 text-center">
        &copy; {new Date().getFullYear()} Century21 Arelys Catena | Real Estate. All rights reserved.
      </div>
    </footer>

  </body>
</html>