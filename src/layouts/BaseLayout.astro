---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = Astro.site ? '' : '/arelysrealestatesite'; // Matches config base
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-slate-800 antialiased flex flex-col min-h-screen">
    <!-- Navbar -->
    <header class="border-b border-slate-100 sticky top-0 bg-white/90 backdrop-blur-md z-50">
      <div class="max-w-7xl mx-auto px-4 h-20 flex justify-between items-center">
        <a href=`${base}/` class="text-xl font-bold text-slate-900 tracking-tight">
          Arelys Catena <span class="text-blue-600 font-normal text-sm">| Real Estate</span>
        </a>
        <nav class="hidden md:flex gap-8 font-medium text-slate-600">
          <a href=`${base}/` class="hover:text-blue-600 transition">Home</a>
          <a href=`${base}/search` class="hover:text-blue-600 transition">Search Homes</a>
          <a href=`${base}/blog` class="hover:text-blue-600 transition">Market News</a>
          <a href=`${base}/reviews` class="hover:text-blue-600 transition">Reviews</a>
        </nav>
        <a href=`${base}/search` class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition">
          MLS Search
        </a>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-12 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
        <div>
          <p class="text-white font-bold text-lg">Arelys Catena</p>
          <p class="text-sm mt-1">Dedicated to finding your dream home and maximizing your investment.</p>
        </div>
        <div class="text-sm text-center md:text-right">
          <p>&copy; {new Date().getFullYear()} All Rights Reserved.</p>
          <p class="text-slate-500 mt-1">Equal Housing Opportunity.</p>
        </div>
      </div>
    </footer>
  </body>
</html>