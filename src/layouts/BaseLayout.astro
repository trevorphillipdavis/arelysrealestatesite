---
import '../styles/global.css';
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-slate-800 antialiased flex flex-col min-h-screen">
    <!-- Navbar -->
    <header class="border-b border-slate-200 sticky top-0 bg-white/95 backdrop-blur-md z-50">
      <div class="max-w-7xl mx-auto px-4 h-20 flex justify-between items-center">
        <a href={`${base}/`} class="text-xl font-bold text-slate-900 tracking-tight flex items-center gap-2">
          <span class="bg-[#C49A45] text-black text-xs font-black px-2 py-1 rounded">C21</span>
          Arelys Catena <span class="text-[#C49A45] font-normal text-sm">| Real Estate</span>
        </a>
        <nav class="hidden md:flex gap-8 font-medium text-slate-600">
          <a href={`/`} class="hover:text-[#C49A45] transition">Home</a>
          <a href={`/search`} class="hover:text-[#C49A45] transition">Search Homes</a>
          <a href={`/blog`} class="hover:text-[#C49A45] transition">Local Market News</a>
          <a href={`/reviews`} class="hover:text-[#C49A45] transition">Reviews</a>
        </nav>
        <div class="flex items-center gap-4">
          <a href="tel:9542923366" class="hidden lg:inline text-sm font-semibold text-slate-700 hover:text-[#C49A45]">
            📞 (954) 292-3366
          </a>
          <a href={`${base}/search`} class="bg-[#C49A45] text-black font-semibold px-4 py-2 rounded-lg text-sm hover:bg-[#b0883d] transition">
            MLS Search
          </a>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-[#111111] text-slate-400 py-12 border-t border-slate-800">
      <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
        <div>
          <p class="text-white font-bold text-lg flex items-center gap-2">
            <span class="bg-[#C49A45] text-black text-xs font-black px-1.5 py-0.5 rounded">C21</span> 
            Arelys Catena
          </p>
          <p class="text-sm mt-1">Direct: <a href="tel:9542923366" class="text-[#C49A45] hover:underline">(954) 292-3366</a></p>
          <p class="text-sm mt-1">Email: <a href="mailto:arelyshomes@gmail.com" class="text-[#C49A45] hover:underline">arelyshomes@gmail.com</a></p>
          <p class="text-sm mt-1">Dedicated to finding your dream home and maximizing your investment.</p>
        </div>

        <!-- Social Media Links -->
        <div class="flex flex-col items-center md:items-end gap-3">
          <p class="text-white text-sm font-semibold">Connect Online</p>
          <div class="flex gap-4 text-sm">
            <a href="https://www.instagram.com/arelyscatena" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#C49A45] transition">Instagram</a>
            <a href="https://www.facebook.com/share/1E1WzQ4ybE/" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#C49A45] transition">Facebook</a>
          </div>
        </div>

        <div class="text-sm text-center md:text-right">
          <p>&copy; {new Date().getFullYear()} Arelys Catena. All Rights Reserved.</p>
          <p class="text-slate-500 mt-1">Equal Housing Opportunity.</p>
        </div>
      </div>
    </footer>
  </body>
</html>