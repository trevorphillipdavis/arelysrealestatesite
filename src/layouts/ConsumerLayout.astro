---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title}>
  <main class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Article Card Container -->
      <article class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 md:p-12">
        
        <!-- Article Header -->
        <div class="mb-8 border-b border-gray-100 pb-8">
          <div class="flex items-center gap-2 mb-4">
            <span class="bg-[#C59B27]/10 text-[#C59B27] font-semibold px-3 py-1 rounded-full text-xs">
              {frontmatter.category}
            </span>
            <span class="text-gray-400 text-xs">{frontmatter.readTime}</span>
            <span class="text-gray-300">•</span>
            <span class="text-gray-400 text-xs">{frontmatter.date}</span>
          </div>
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            {frontmatter.title}
          </h1>
        </div>

        <!-- Markdown Body Content with Proper Typography Styling -->
        <div class="prose max-w-none text-gray-700 space-y-6 leading-relaxed [&>h2]:text-2xl [&>h2]:font-bold [&>h2]:text-gray-900 [&>h2]:mt-8 [&>h2]:mb-4">
          <slot />
        </div>

        <!-- Article Footer / CTA -->
        <div class="mt-12 pt-8 border-t border-gray-100 flex flex-col sm:flex-row items-center justify-between gap-4">
          <a href="/consumer-education" class="text-sm font-semibold text-[#C59B27] hover:underline">
            <i class="fa-solid fa-arrow-left mr-2"></i> Back to Consumer Education Hub
          </a>
          <a href="tel:9542923366" class="bg-[#C59B27] hover:bg-[#b0881f] text-white font-semibold px-6 py-2.5 rounded-lg text-sm shadow-sm transition-colors">
            Contact Arelys
          </a>
        </div>

      </article>

    </div>
  </main>
</BaseLayout>