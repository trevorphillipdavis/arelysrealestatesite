---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title}>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <div class="mb-6">
      <a href="/blog" class="text-amber-600 font-semibold hover:underline inline-flex items-center text-sm">
        &larr; Back to Local Market News
      </a>
    </div>

    <article class="bg-white p-8 rounded-xl border border-gray-200 shadow-sm">
      <div class="mb-6 border-b border-gray-100 pb-6">
        <span class="text-xs font-semibold px-2.5 py-1 bg-amber-100 text-amber-800 rounded-full">
          Published: {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </span>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-4 mb-3">{post.data.title}</h1>
        <p class="text-gray-600 text-base">{post.data.description}</p>
      </div>

      <div class="prose prose-amber max-w-none text-gray-700 space-y-6 leading-relaxed blog-content">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  /* Automatically bold and underline specific subheadings for all blog posts moving forward */
  .blog-content :global(h3) {
    font-weight: 700;
    text-decoration: underline;
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: #111827;
  }
</style>