---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Real Estate News & Blog">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Market Insights & News</h1>
    <p class="text-slate-600 mb-8">Curated updates on local market conditions, buying tips, and home maintenance.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <article class="border border-slate-200 rounded-xl p-6 bg-white shadow-sm">
        <span class="text-xs font-semibold text-blue-600 uppercase tracking-wider">Market Report</span>
        <h3 class="text-xl font-semibold text-slate-800 mt-2">Spring Housing Market Trends to Watch</h3>
        <p class="text-slate-600 text-sm mt-2">A quick breakdown of inventory changes, mortgage rates, and what they mean for buyers and sellers this season.</p>
      </article>
    </div>
  </div>
</BaseLayout>