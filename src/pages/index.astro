---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '/';
---
<BaseLayout title="Arelys Catena | Century 21 Real Estate Professional">
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-[#C49A45] font-bold tracking-wider uppercase text-sm">Century 21 Real Estate Professional</span>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mt-2 mb-6">
          Find Your Next Home With Arelys Catena
        </h1>
        <p class="text-lg text-slate-600 mb-8">
          Providing expert local market knowledge, unmatched negotiation skills, and dedicated personal service.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href={`${base}/search`} class="bg-[#C49A45] text-black font-semibold px-6 py-3 rounded-lg text-center hover:bg-[#b0883d] transition shadow-md">
            Search MLS Listings
          </a>
          <a href="tel:9542923366" class="border border-slate-300 text-slate-700 font-medium px-6 py-3 rounded-lg text-center hover:bg-slate-100 transition">
            Call: (954) 292-3366
          </a>
        </div>
      </div>
      <div class="flex justify-center">
        <img 
          src={`${base}/images/arelysphoto.webp`} 
          alt="Arelys Catena Headshot" 
          class="rounded-2xl shadow-2xl object-cover w-80 h-96 md:w-96 md:h-[450px] bg-slate-200 border-2 border-[#C49A45]"
        />
      </div>
    </div>
  </section>
</BaseLayout>