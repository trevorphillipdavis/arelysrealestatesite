---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = '';
---
<BaseLayout title="Home | Realtor Services">
  <!-- Hero -->
  <section class="py-16 md:py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="text-blue-600 font-semibold tracking-wider uppercase text-sm">Professional Real Estate Agent</span>
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mt-2 mb-6">
          Find Your Next Home With Confidence
        </h1>
        <p class="text-lg text-slate-600 mb-8">
          Providing expert local market knowledge, unmatched negotiation skills, and dedicated personal service.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="./search" class="bg-blue-600 text-white font-medium px-6 py-3 rounded-lg text-center hover:bg-blue-700 transition">
            Search MLS Listings
          </a>
          <a href="tel:5555555555" class="border border-slate-300 text-slate-700 font-medium px-6 py-3 rounded-lg text-center hover:bg-slate-100 transition">
            Call: (555) 555-5555
          </a>
        </div>
      </div>
      <div class="flex justify-center">
        <img 
          src="./images/realtor-headshot.jpg" 
          alt="Realtor Headshot" 
          class="rounded-2xl shadow-2xl object-cover w-80 h-96 md:w-96 md:h-[450px] bg-slate-200"
        />
      </div>
    </div>
  </section>
</BaseLayout>