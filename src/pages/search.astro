---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Search South Florida Homes for Sale | MLS Search" 
  description="Browse active real estate listings, homes for sale, and condos across Broward and Miami-Dade counties with Arelys Catena."
>
  <!-- Tightened top padding -->
  <main class="pt-12 md:pt-16 pb-12 bg-gray-50 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="text-center mb-6">
        <span class="text-[#C59B27] font-bold tracking-wider uppercase text-xs sm:text-sm">Find Your Property</span>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-1 mb-2">
          Search South Florida Homes
        </h1>
        <p class="text-sm md:text-base text-gray-600 max-w-2xl mx-auto">
          Explore active MLS listings, filter by property type, price, and location across Broward and Miami-Dade County.
        </p>
      </div>

      <!-- IDX / MLS Integration Wrapper -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-4 md:p-8">
        <div id="IDX-main" class="w-full">
          <iframe src="https://matrix.beachesmls.com/Matrix/public/IDX.aspx?idx=1cdeea" width="100%" height="800px" frameborder="0" marginwidth="0" marginheight="0"></iframe>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>