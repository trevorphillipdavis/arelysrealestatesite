---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search Homes | MLS Feed">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <span class="text-[#C49A45] font-bold tracking-wider uppercase text-sm">MLS Property Feed</span>
      <h1 class="text-3xl font-bold text-slate-900 mt-2">Live Property Search</h1>
      <p class="text-slate-600 mt-2">Explore active local listings directly from Arelys's property portal.</p>
    </div>

    <!-- IDX Iframe Container -->
    <div class="bg-white border border-slate-200 rounded-2xl p-4 shadow-sm w-full overflow-hidden">
      <!-- PASTE YOUR IDX IFRAME CODE HERE -->
<iframe src="https://matrix.beachesmls.com/Matrix/public/IDX.aspx?idx=1cdeea" width="100%" height="100%" frameborder="0" marginwidth="0" marginheight="0"></iframe>
    </div>
  </div>
</BaseLayout>