---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Search Homes | MLS Feed">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl font-bold text-slate-900">Live Property Search</h1>
      <p class="text-slate-600 mt-2">Explore active listings directly from the local MLS database.</p>
    </div>
    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-12 text-center max-w-2xl mx-auto shadow-sm">
      <h3 class="text-xl font-semibold text-slate-800 mb-3">Ready to browse properties?</h3>
      <p class="text-slate-600 mb-6">Open our secure, interactive property portal to filter by price, neighborhood, and features.</p>
      <a href="https://your-idx-provider-link.com" target="_blank" rel="noopener" class="bg-[#C49A45] text-black font-semibold px-8 py-4 rounded-xl shadow hover:bg-[#b0883d] transition inline-block">
        Launch IDX Property Search &rarr;
      </a>
    </div>
  </div>
</BaseLayout>