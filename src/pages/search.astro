---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Search South Florida Homes for Sale | MLS Search" 
  description="Browse active real estate listings, homes for sale, and condos across Broward and Miami-Dade counties with Arelys Catena."
>
  <main class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="text-center mb-16">
        <span class="text-[#C59B27] font-bold tracking-wider uppercase text-sm">Find Your Property</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-2 mb-4">
          Search South Florida Homes
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Explore active MLS listings, filter by property type, price, and location, and find your dream home in Broward or Miami-Dade County.
        </p>
      </div>

      <!-- Search Interface / Content Card -->
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 md:p-12 text-center">
        <div class="max-w-xl mx-auto py-12">
          <div class="w-16 h-16 bg-[#C59B27]/10 text-[#C59B27] rounded-full flex items-center justify-center mx-auto mb-6 text-2xl">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">MLS Search Tool Integration</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">
            Ready to browse live inventory or set up custom property alerts tailored to your exact criteria? Get in touch with Arelys for direct access.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="tel:9542923366" class="bg-[#C59B27] hover:bg-[#b0881f] text-white font-semibold px-6 py-3 rounded-xl shadow transition">
              <i class="fa-solid fa-phone mr-2"></i> Call (954) 292-3366
            </a>
            <a href="mailto:arelyshomes@gmail.com" class="bg-gray-900 hover:bg-gray-800 text-white font-semibold px-6 py-3 rounded-xl shadow transition">
              <i class="fa-solid fa-envelope mr-2"></i> Email Arelys
            </a>
          </div>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>