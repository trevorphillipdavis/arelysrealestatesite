---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Client Reviews & Testimonials">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-slate-900 mb-2">Client Testimonials</h1>
    <p class="text-slate-600 mb-8">See what past clients have to say about working together.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-6 shadow-sm">
        <p class="text-amber-500 font-bold mb-2">★★★★★</p>
        <p class="text-slate-700 italic">"Working together made buying our first home completely seamless. Expert negotiation and absolute professionalism throughout!"</p>
        <p class="text-slate-500 text-sm font-semibold mt-4">— Sarah & Mark T.</p>
      </div>
    </div>
  </div>
</BaseLayout>