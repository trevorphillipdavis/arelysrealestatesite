---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Client Reviews & Testimonials | Arelys Catena">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="max-w-3xl mb-12">
      <span class="text-[#C49A45] font-bold tracking-wider uppercase text-sm">Social Proof</span>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mt-2">Client Testimonials</h1>
      <p class="text-slate-600 mt-2">See what past buyers and sellers have to say about working with Arelys.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-slate-50 border border-slate-200 rounded-xl p-6 shadow-sm">
        <p class="text-[#C49A45] font-bold mb-2">★★★★★</p>
        <p class="text-slate-700 italic">"Arelys made buying our first home completely seamless. Expert negotiation and absolute professionalism throughout!"</p>
        <p class="text-slate-500 text-sm font-semibold mt-4">— Sarah & Mark T.</p>
      </div>
    </div>
  </div>
</BaseLayout>