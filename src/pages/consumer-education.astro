---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Consumer Education | Arelys Catena Real Estate">
  <main class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="text-center mb-16">
        <span class="text-[#C59B27] font-bold tracking-wider uppercase text-sm">Knowledge is Power</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-2 mb-4">
          Consumer Education Hub
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Navigate your real estate journey with confidence. Explore our expert guides, tips, and resources designed to help buyers and sellers make informed decisions.
        </p>
      </div>

      <!-- Articles / Guides Grid -->
      <div class="space-y-8">
        
        <!-- Guide 1 -->
        <article class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-2 mb-3">
            <span class="bg-[#C59B27]/10 text-[#C59B27] font-semibold px-3 py-1 rounded-full text-xs">Buyers Guide</span>
            <span class="text-gray-400 text-xs">5 min read</span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">
            First-Time Homebuyer's Roadmap: What to Expect in South Florida
          </h2>
          <p class="text-gray-600 mb-6">
            Purchasing your first home is an exciting milestone. Learn about pre-approval, navigating the local market, making competitive offers, and what happens during escrow.
          </p>
          <a href="/search" class="inline-flex items-center text-[#C59B27] font-semibold hover:underline">
            Start Searching Listings <i class="fa-solid fa-arrow-right ml-2 text-sm"></i>
          </a>
        </article>

        <!-- Guide 2 -->
        <article class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-2 mb-3">
            <span class="bg-[#C59B27]/10 text-[#C59B27] font-semibold px-3 py-1 rounded-full text-xs">Sellers Guide</span>
            <span class="text-gray-400 text-xs">7 min read</span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">
            Maximizing Your Property Value Before Listing
          </h2>
          <p class="text-gray-600 mb-6">
            Discover simple staging techniques, high-impact minor repairs, and effective marketing strategies that can significantly increase your home's final selling price.
          </p>
          <a href="tel:9542923366" class="inline-flex items-center text-[#C59B27] font-semibold hover:underline">
            Call for a Free Home Valuation <i class="fa-solid fa-arrow-right ml-2 text-sm"></i>
          </a>
        </article>

        <!-- Guide 3 -->
        <article class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 hover:shadow-md transition-shadow">
          <div class="flex items-center gap-2 mb-3">
            <span class="bg-[#C59B27]/10 text-[#C59B27] font-semibold px-3 py-1 rounded-full text-xs">Market Insights</span>
            <span class="text-gray-400 text-xs">4 min read</span>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">
            Understanding Real Estate Negotiations and Closing Costs
          </h2>
          <p class="text-gray-600 mb-6">
            Closing costs and negotiations can catch buyers and sellers off guard. Break down standard fees, inspection contingencies, and how expert representation saves you money.
          </p>
          <a href="/blog" class="inline-flex items-center text-[#C59B27] font-semibold hover:underline">
            Read Local Market News <i class="fa-solid fa-arrow-right ml-2 text-sm"></i>
          </a>
        </article>

      </div>

      <!-- Call to Action Banner -->
      <div class="mt-16 bg-[#C59B27] text-white rounded-2xl p-8 md:p-12 text-center shadow-lg">
        <h2 class="text-3xl font-bold mb-4">Have Specific Real Estate Questions?</h2>
        <p class="text-white/90 max-w-xl mx-auto mb-8">
          Every real estate transaction is unique. Reach out to Arelys directly for personalized guidance tailored to your goals.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="tel:9542923366" class="bg-white text-gray-900 font-semibold px-6 py-3 rounded-lg shadow hover:bg-gray-100 transition">
            <i class="fa-solid fa-phone text-[#C59B27] mr-2"></i> (954) 292-3366
          </a>
          <a href="mailto:arelyshomes@gmail.com" class="bg-gray-900 text-white font-semibold px-6 py-3 rounded-lg shadow hover:bg-gray-800 transition">
            <i class="fa-solid fa-envelope text-[#C59B27] mr-2"></i> Email Arelys
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>