---
import BaseLayout from '../layouts/BaseLayout.astro';

// Your list of consumer education articles
const articles = [
  {
    slug: 'first-time-homebuyer-roadmap',
    category: "Buyers Guide",
    readTime: "5 min read",
    title: "First-Time Homebuyer's Roadmap: What to Expect in South Florida",
    excerpt: "Purchasing your first home is an exciting milestone. Here is a step-by-step breakdown of how to navigate the market with total confidence.",
    date: "July 2026"
  }
];
---

<BaseLayout 
  title="Consumer Education & Real Estate Guides | Arelys Catena" 
  description="Explore expert guides, homebuying roadmaps, and seller tips designed to help you navigate the South Florida real estate market."
>
  <main class="py-16 md:py-24 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Page Header -->
      <div class="text-center mb-16">
        <span class="text-[#C59B27] font-bold tracking-wider uppercase text-sm">Knowledge is Power</span>
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mt-2 mb-4">
          Consumer Education Hub
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Explore our latest blog posts, expert guides, and educational articles designed to help buyers and sellers make informed real estate decisions.
        </p>
      </div>

      <!-- Articles Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {articles.map((article) => (
          <article class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div>
              <div class="flex items-center justify-between mb-3">
                <span class="bg-[#C59B27]/10 text-[#C59B27] font-semibold px-3 py-1 rounded-full text-xs">
                  {article.category}
                </span>
                <span class="text-gray-400 text-xs">{article.readTime}</span>
              </div>
              <h2 class="text-2xl font-bold text-gray-900 mb-3 hover:text-[#C59B27] transition-colors">
                <a href={`/consumer-education/${article.slug}`}>{article.title}</a>
              </h2>
              <p class="text-gray-600 mb-6 text-sm leading-relaxed">
                {article.excerpt}
              </p>
            </div>
            <div class="pt-4 border-t border-gray-100 flex items-center justify-between text-xs text-gray-500">
              <span>{article.date}</span>
              <a href={`/consumer-education/${article.slug}`} class="inline-flex items-center text-[#C59B27] font-semibold hover:underline">
                Read Article <i class="fa-solid fa-arrow-right ml-1.5 text-xs"></i>
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Call to Action Banner -->
      <div class="mt-16 bg-[#C59B27] text-white rounded-2xl p-8 md:p-12 text-center shadow-lg">
        <h2 class="text-3xl font-bold mb-4">Have Specific Real Estate Questions?</h2>
        <p class="text-white/90 max-w-xl mx-auto mb-8">
          Every real estate transaction is unique. Reach out to Arelys directly for personalized guidance tailored to your goals.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="tel:9542923366" class="bg-white text-gray-900 font-semibold px-6 py-3 rounded-lg shadow hover:bg-gray-100 transition">
            <i class="fa-solid fa-phone text-[#C59B27] mr-2"></i> (954) 292-3366
          </a>
          <a href="mailto:arelyshomes@gmail.com" class="bg-gray-900 text-white font-semibold px-6 py-3 rounded-lg shadow hover:bg-gray-800 transition">
            <i class="fa-solid fa-envelope text-[#C59B27] mr-2"></i> Email Arelys
          </a>
        </div>
      </div>

    </div>
  </main>
</BaseLayout>